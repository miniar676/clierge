# MySQL connection (used by the Express API in server/)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=clierge

# Port the Express API listens on (hosting providers like Render set PORT automatically)
API_PORT=3001

# Allowed origin(s) for the API's CORS policy. Use * for any, or your frontend URL in production.
CORS_ORIGIN=*

# Frontend: base URL of the deployed API, e.g. https://clierge-api.onrender.com
# Leave empty for local dev (Vite proxies /api to the backend).
VITE_API_URL=

# Email notifications via Resend (https://resend.com — free 3,000 emails/month).
# Sign up at resend.com, create an API key, and paste it here.
# If empty, notification emails are skipped silently.
RESEND_API_KEY=
# Where notification emails are sent (defaults to clierge.solution@gmail.com).
NOTIFY_EMAIL=
