# MySQL connection (used by the Express API in server/)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=clierge

# Port the Express API listens on (hosting providers like Render set PORT automatically)
API_PORT=3001

# Allowed origin(s) for the API's CORS policy. Use * for any, or your frontend URL in production.
CORS_ORIGIN=*

# Frontend: base URL of the deployed API, e.g. https://clierge-api.onrender.com
# Leave empty for local dev (Vite proxies /api to the backend).
VITE_API_URL=

# Email notifications for new contact form submissions (sent via Gmail SMTP).
# GMAIL_USER must be a Gmail address with an App Password (requires 2-Step Verification):
# https://myaccount.google.com/apppasswords
# If GMAIL_USER or GMAIL_APP_PASSWORD is empty, notification emails are skipped.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Where notification emails are sent. Defaults to GMAIL_USER if left empty.
NOTIFY_EMAIL=
